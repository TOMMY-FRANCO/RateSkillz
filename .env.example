# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Application Configuration
# The public URL where your application is hosted
VITE_APP_URL=http://localhost:5173

# Google reCAPTCHA Configuration (Optional)
# Required for signup form protection. Get from: https://www.google.com/recaptcha/admin
# If not provided, signup will work but without reCAPTCHA verification
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
