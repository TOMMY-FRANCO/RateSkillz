# =============================================================================
# RatingSkill - Environment Variables Configuration
# =============================================================================
# This file documents all environment variables required for the application.
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# These are the core credentials for your Supabase backend database and APIs.
# Get these from: https://app.supabase.com/project/_/settings/api
#
# Usage:
# - VITE_SUPABASE_URL: Used by the frontend client to connect to Supabase
# - VITE_SUPABASE_ANON_KEY: Public anonymous key for client-side operations
#
# Security: The anon key is safe to expose in frontend code. It has RLS
# (Row Level Security) restrictions and can only perform authorized operations.
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# The public URL where your application is hosted.
#
# Usage:
# - Used for generating absolute URLs (QR codes, share links, email links)
# - Used for OAuth redirect URLs
# - Used in meta tags for social sharing
#
# Examples:
# - Development: http://localhost:5173
# - Production: https://ratingskill.com
# -----------------------------------------------------------------------------

VITE_APP_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# GOOGLE reCAPTCHA v3 (OPTIONAL)
# -----------------------------------------------------------------------------
# Protects signup forms from bots and abuse.
# Get from: https://www.google.com/recaptcha/admin
#
# Usage:
# - VITE_RECAPTCHA_SITE_KEY: Public site key (client-side)
# - Used in: src/pages/Signup.tsx for bot protection during registration
#
# If not provided: Signup will work but without reCAPTCHA verification
#
# Security: Site key is public and safe to expose in frontend code.
# -----------------------------------------------------------------------------

VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here


# =============================================================================
# SERVER-SIDE ENVIRONMENT VARIABLES (Supabase Edge Functions)
# =============================================================================
# These variables are configured in the Supabase Dashboard, NOT in this file.
# Go to: https://app.supabase.com/project/_/settings/functions
#
# They are documented here for reference only.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE SERVICE CREDENTIALS (AUTO-PROVISIONED)
# -----------------------------------------------------------------------------
# These are automatically available in all Edge Functions.
# You don't need to set these manually.
#
# - SUPABASE_URL: Your Supabase project URL (same as VITE_SUPABASE_URL)
# - SUPABASE_SERVICE_ROLE_KEY: Admin key with full database access
# - SUPABASE_DB_URL: Direct database connection string
# - SUPABASE_ANON_KEY: Anonymous key (same as VITE_SUPABASE_ANON_KEY)
#
# Security: NEVER expose the service role key in frontend code!
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# STRIPE PAYMENT PROCESSING (OPTIONAL)
# -----------------------------------------------------------------------------
# Required only if you want to enable coin purchases via Stripe.
# Get from: https://dashboard.stripe.com/apikeys
#
# Server-side secrets (set in Supabase Dashboard):
# - STRIPE_SECRET_KEY: Your Stripe secret key (starts with sk_test_ or sk_live_)
# - STRIPE_WEBHOOK_SECRET: Webhook signing secret for verifying Stripe events
#
# Usage:
# - Used in: supabase/functions/stripe-checkout/index.ts
# - Used in: supabase/functions/stripe-webhook/index.ts
#
# How to set:
# 1. Go to Supabase Dashboard > Edge Functions > Secrets
# 2. Add: STRIPE_SECRET_KEY = sk_test_...
# 3. Add: STRIPE_WEBHOOK_SECRET = whsec_...
#
# Security: NEVER commit Stripe secret keys to version control!
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# GOOGLE reCAPTCHA v3 SECRET (OPTIONAL)
# -----------------------------------------------------------------------------
# Server-side secret for verifying reCAPTCHA tokens.
# Get from: https://www.google.com/recaptcha/admin (same site as site key)
#
# Server-side secret (set in Supabase Dashboard):
# - RECAPTCHA_SECRET_KEY: Secret key for server-side verification
#
# Usage:
# - Used in: supabase/functions/signup-verification/index.ts
# - Validates reCAPTCHA tokens submitted from the frontend
#
# How to set:
# 1. Go to Supabase Dashboard > Edge Functions > Secrets
# 2. Add: RECAPTCHA_SECRET_KEY = 6L...
#
# Security: NEVER expose the secret key in frontend code!
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# RESEND EMAIL API (OPTIONAL)
# -----------------------------------------------------------------------------
# Required only if you want to send password reset emails via Resend.
# Get from: https://resend.com/api-keys
#
# Server-side secret (set in Supabase Dashboard):
# - RESEND_API_KEY: Your Resend API key (starts with re_)
#
# Usage:
# - Used in: supabase/functions/password-reset-email/index.ts
# - Sends password reset emails to users
#
# How to set:
# 1. Create an account at https://resend.com
# 2. Generate an API key
# 3. Go to Supabase Dashboard > Edge Functions > Secrets
# 4. Add: RESEND_API_KEY = re_...
#
# Alternative: You can use Supabase's built-in email service instead
#
# Security: NEVER commit API keys to version control!
# -----------------------------------------------------------------------------


# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
#
# Required for basic functionality:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - VITE_APP_URL
#
# Optional but recommended:
# - VITE_RECAPTCHA_SITE_KEY (protects against bot signups)
# - RECAPTCHA_SECRET_KEY (server-side verification)
#
# Optional for premium features:
# - STRIPE_SECRET_KEY (enables coin purchases)
# - STRIPE_WEBHOOK_SECRET (processes payment confirmations)
# - RESEND_API_KEY (enables password reset emails)
#
# =============================================================================
#
# How to set up:
# 1. Copy this file: cp .env.example .env
# 2. Fill in VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY from Supabase
# 3. Set VITE_APP_URL to your local or production URL
# 4. (Optional) Add reCAPTCHA keys for bot protection
# 5. (Optional) Configure Stripe in Supabase Dashboard for payments
# 6. (Optional) Configure Resend in Supabase Dashboard for emails
#
# =============================================================================
#
# Troubleshooting:
# - If you see "Invalid API key" errors, check your Supabase credentials
# - If payments don't work, ensure STRIPE_SECRET_KEY is set in Supabase
# - If emails don't send, ensure RESEND_API_KEY is set in Supabase
# - If reCAPTCHA fails, check both site key and secret key are correct
#
# =============================================================================
